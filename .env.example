# Public app metadata
NEXT_PUBLIC_APP_NAME=Atlas Swap Agent
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LI.FI SDK configuration
NEXT_PUBLIC_LIFI_INTEGRATOR=atlas-swap-agent
NEXT_PUBLIC_LIFI_API_URL=https://li.quest/v1
NEXT_PUBLIC_DEFAULT_SLIPPAGE_BPS=50
NEXT_PUBLIC_DEFAULT_ROUTE_PREFERENCE=recommended

# Wallet connectivity
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Public RPC map exposed to the browser for LI.FI + wallet execution
# JSON object: { "1": ["https://..."], "8453": ["https://..."] }
NEXT_PUBLIC_RPC_URL_MAP={"1":["https://ethereum-rpc.publicnode.com"],"8453":["https://base-rpc.publicnode.com"],"42161":["https://arbitrum-one-rpc.publicnode.com"],"10":["https://optimism-rpc.publicnode.com"],"137":["https://polygon-bor-rpc.publicnode.com"],"56":["https://bsc-rpc.publicnode.com"]}

# Optional observability
NEXT_PUBLIC_ENABLE_DEBUG=true
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_WRITE_KEY=

# Optional token list URLs as JSON array or comma-separated list
NEXT_PUBLIC_TOKEN_LIST_URLS=["https://tokens.coingecko.com/uniswap/all.json"]

# Optional LLM parser enhancement
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
